# Normalize line endings: store LF in the repo and check out LF everywhere.
# Prevents Windows CRLF vs LF churn (the "thousands of changed files" problem)
# in editors/Source Control. Binary files are auto-detected and left untouched.
* text=auto eol=lf

# Be explicit about common binaries so they are never line-ending converted.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.mp4   binary
*.webm  binary
