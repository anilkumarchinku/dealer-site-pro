# ── Cloudflare (DNS & CDN) ──────────────
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ZONE_ID=your_zone_id_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# ── Resend (Email Service) ──────────────
RESEND_API_KEY=re_xxxxxxxxxxxxx

# ── Google Places API (Reviews Sync) ────
# Enable Places API in Google Cloud Console → APIs & Services
# Get key from: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ── Anthropic (AI Features) ─────────────
# Get API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── RC / Vehicle Lookup ─────────────────
# Provider options: 'surepass' | 'rapidor' | 'mock' (default: mock in dev)
# NOTE: configured at the top of this file (RC_LOOKUP_PROVIDER=surepass).
# Do not re-declare it here — dotenv keeps the LAST value and it would override.
# Rapidor API — https://rapidor.co (free tier available)
RAPIDOR_API_KEY=

# ── Cyepro Inventory API ────────────────
# Dealer API keys are saved per dealer in Dashboard → Settings → Integrations.
# This base URL can point to mock/salesapp/dev/prod Cyepro API hosts.
CYEPRO_API_BASE_URL=https://salesapp.cyepro.com
CYEPRO_SEARCH_PATH=/dynamicForms/search/vehicles/filterQueryApi
CYEPRO_AGGREGATIONS_PATH=/dynamicForms/search/vehicles/aggregationsApi

# ── MSG91 (SMS Notifications) ───────────
# Get Auth Key from: https://msg91.com → Dashboard → API Keys
# Register a Sender ID (e.g. DLRPRO) for DLT compliance
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_SENDER_ID=DLRPRO
# Optional: MSG91 Flow template ID for DLT-compliant lead notification SMS
MSG91_LEAD_TEMPLATE_ID=

# ── Security ────────────────────────────
CRON_SECRET=your_random_secret_here_change_this

# ── GitHub (Dealer Repo Management) ─────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_ORG=your-github-org-name
GITHUB_TEMPLATE_REPO=dealer-custom-site

# ── Vercel (Deployment Platform) ────────
VERCEL_TOKEN=vcp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VERCEL_MAIN_PROJECT_ID=prj_xxxxxxxxxxxxxxxx

# ── Social Media Auto-Post (Task #14) ───
