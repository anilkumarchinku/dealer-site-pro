# ========================================
# ENVIRONMENT CONFIGURATION - TEMPLATE
# ========================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env to Git!

# ── Domain Configuration ────────────────
NEXT_PUBLIC_BASE_DOMAIN=localhost:3000
NEXT_PUBLIC_USE_SUBDOMAIN=false

# ── Supabase (Database & Auth) ──────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── GoDaddy (Domain Management) ─────────
GODADDY_API_KEY=your_godaddy_api_key_here
GODADDY_API_SECRET=your_godaddy_api_secret_here
GODADDY_API_URL=https://api.godaddy.com

# ── Razorpay (Payments) ─────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key_here
RAZORPAY_PRO_PLAN_ID=plan_xxxxxxxxxxxxx
RAZORPAY_PREMIUM_PLAN_ID=plan_xxxxxxxxxxxxx

# ── Cloudflare (DNS & CDN) ──────────────
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ZONE_ID=your_zone_id_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# ── Resend (Email Service) ──────────────
RESEND_API_KEY=re_xxxxxxxxxxxxx

# ── Security ────────────────────────────
CRON_SECRET=your_random_secret_here_change_this

# ── GitHub (Dealer Repo Management) ─────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_ORG=your-github-org-name
GITHUB_TEMPLATE_REPO=dealer-custom-site

# ── Vercel (Deployment Platform) ────────
VERCEL_TOKEN=vcp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VERCEL_MAIN_PROJECT_ID=prj_xxxxxxxxxxxxxxxx
