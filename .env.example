# ========================================
# ENVIRONMENT CONFIGURATION - TEMPLATE
# ========================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env to Git!

# ── Domain Configuration ────────────────
NEXT_PUBLIC_BASE_DOMAIN=localhost:3000
NEXT_PUBLIC_USE_SUBDOMAIN=false

# ── Supabase (Database & Auth) ──────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── GoDaddy (Domain Management) ─────────
GODADDY_API_KEY=your_godaddy_api_key_here
GODADDY_API_SECRET=your_godaddy_api_secret_here
GODADDY_API_URL=https://api.godaddy.com

# ── Razorpay (Payments) ─────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key_here
RAZORPAY_PRO_PLAN_ID=plan_xxxxxxxxxxxxx
RAZORPAY_PREMIUM_PLAN_ID=plan_xxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ── Cloudflare (DNS & CDN) ──────────────
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ZONE_ID=your_zone_id_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# ── Resend (Email Service) ──────────────
RESEND_API_KEY=re_xxxxxxxxxxxxx

# ── Anthropic (AI Features) ─────────────
# Get API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── RC / Vehicle Lookup ─────────────────
# Provider options: 'rapidor' | 'mock' (default: mock)
RC_LOOKUP_PROVIDER=mock
# Rapidor API — https://rapidor.co (free tier available)
RAPIDOR_API_KEY=

# ── MSG91 (SMS Notifications) ───────────
# Get Auth Key from: https://msg91.com → Dashboard → API Keys
# Register a Sender ID (e.g. DLRPRO) for DLT compliance
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_SENDER_ID=DLRPRO
# Optional: MSG91 Flow template ID for DLT-compliant lead notification SMS
MSG91_LEAD_TEMPLATE_ID=

# ── Security ────────────────────────────
CRON_SECRET=your_random_secret_here_change_this

# ── GitHub (Dealer Repo Management) ─────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_ORG=your-github-org-name
GITHUB_TEMPLATE_REPO=dealer-custom-site

# ── Vercel (Deployment Platform) ────────
VERCEL_TOKEN=vcp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VERCEL_MAIN_PROJECT_ID=prj_xxxxxxxxxxxxxxxx

# ── Social Media Auto-Post (Task #14) ───
# Facebook & Instagram — Meta for Developers: https://developers.facebook.com
META_PAGE_ID=your_facebook_page_id
META_PAGE_ACCESS_TOKEN=your_long_lived_page_access_token
META_IG_USER_ID=your_instagram_business_account_id

# Twitter / X — developer.twitter.com
TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAxxxx
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
